      "label": "Hindi notes and study materials"
    },
    {
      "src": "/screenshots/quiz-1.webp",
      "sizes": "1080x1920",
      "type": "image/webp",
      "platform": "wide",
      "label": "Practice quizzes in Hindi"
    }
  ],

  "shortcuts": [
    {
      "name": "Current Affairs",
      "short_name": "Current",
      "description": "Daily current affairs in Hindi",
      "url": "/current-affairs.html",
      "icons": [
        {
          "src": "/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "History Notes",
      "short_name": "History",
      "description": "Access History study notes",
      "url": "/history.html",
      "icons": [
        {
          "src": "/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Practice Quiz",
      "short_name": "Quiz",
      "description": "Take practice tests in Hindi",
      "url": "/mediaeval_mcqs.html",
      "icons": [
        {
          "src": "/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Tools",
      "short_name": "Tools",
      "description": "Edit images and signatures for your exam",
      "url": "/tools.html",
      "icons": [
        {
          "src": "/icons/icon-96x96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://upsc-jet.vercel.app/manifest.json"
    }
  ],

  "prefer_related_applications": false,

  "display_override": [
    "standalone",
    "fullscreen",
    "minimal-ui"
  ],

  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },

  "handle_links": "preferred",

  "share_target": {
    "action": "/share-handler",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "url_handlers": [
    {
      "origin": "https://upsc-jet.vercel.app"
    }
  ],

  "scope_extensions": [
    {
      "origin": "https://upsc-jet.vercel.app"
    }
  ],

  "features": [
    "Offline Study",
    "Hindi Interface",
    "PDF Reader"
  ]
}
